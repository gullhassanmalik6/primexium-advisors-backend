# Application
APP_NAME=Primexium Consultants API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (local Postgres or Neon — never commit real credentials)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/primexium_db
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# JWT
SECRET_KEY=change-this-to-a-secure-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated frontend origins — no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://primexiumadvisors.com,https://www.primexiumadvisors.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend + password reset
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_EXPIRE_MINUTES=60

# Optional SMTP (if empty, reset links are logged / returned when DEBUG=true)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
